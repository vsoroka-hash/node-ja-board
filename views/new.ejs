<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Додати оголошення</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/icons.css">
  <script defer src="/app.js"></script>
</head>
<body>
  <div class="page-shell">
    <div class="container">
      <header class="header-modern">
        <div class="logo">
          <h1><span class="icon icon-add"></span> Додати оголошення</h1>
          <p class="header-subtitle">Створіть новий запис для дошки Premium.</p>
        </div>
        <div class="header-actions">
          <a href="/" class="btn btn-secondary">На головну</a>
        </div>
      </header>

      <main id="main-content" tabindex="-1">
        <form method="POST" class="form">
          <div class="form-group">
            <label>Категорія</label>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="category" value="sale" <%= data?.category === 'sale' ? 'checked' : '' %> required>
                <span class="radio-icon">📦</span> Продаж
              </label>
              <label class="radio-label">
                <input type="radio" name="category" value="service" <%= data?.category === 'service' ? 'checked' : '' %> required>
                <span class="radio-icon">🔧</span> Послуги
              </label>
              <label class="radio-label">
                <input type="radio" name="category" value="job" <%= data?.category === 'job' ? 'checked' : '' %> required>
                <span class="radio-icon">💼</span> Робота
              </label>
              <label class="radio-label">
                <input type="radio" name="category" value="other" <%= data?.category === 'other' ? 'checked' : '' %> required>
                <span class="radio-icon">📌</span> Інше
              </label>
            </div>
            <% if (errors.category) { %>
              <span class="error"><%= errors.category %></span>
            <% } %>
          </div>

          <div class="form-group">
            <label for="title">Назва <span class="required">*</span></label>
            <input type="text" id="title" name="title" value="<%= data?.title || '' %>" placeholder="Коротка назва оголошення" required minlength="5" maxlength="100">
            <% if (errors.title) { %>
              <span class="error"><%= errors.title %></span>
            <% } %>
          </div>

          <div class="form-group">
            <label for="description">Опис <span class="required">*</span></label>
            <textarea id="description" name="description" rows="6" placeholder="Детальний опис оголошення..." required minlength="10"><%= data?.description || '' %></textarea>
            <% if (errors.description) { %>
              <span class="error"><%= errors.description %></span>
            <% } %>
          </div>

          <div class="form-group">
            <label for="price">Ціна (грн) <span class="required">*</span></label>
            <input type="number" id="price" name="price" value="<%= data?.price || '' %>" min="0.01" step="0.01" placeholder="0.00" required>
            <% if (errors.price) { %>
              <span class="error"><%= errors.price %></span>
            <% } %>
          </div>

          <div class="form-group">
            <label for="contactInfo">Контактна інформація <span class="required">*</span></label>
            <input type="text" id="contactInfo" name="contactInfo" value="<%= data?.contactInfo || '' %>" placeholder="Email або телефон" required minlength="5">
            <% if (errors.contactInfo) { %>
              <span class="error"><%= errors.contactInfo %></span>
            <% } %>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary">Опублікувати</button>
            <a href="/" class="btn btn-secondary">Скасувати</a>
          </div>
        </form>
      </main>
    </div>
  </div>
</body>
</html>
