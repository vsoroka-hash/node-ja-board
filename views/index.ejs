<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Дошка оголошень</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/theme.css">
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/icons.css">
  <script defer src="/app.js"></script>
</head>
<body>
  <div class="page-shell">
    <div class="container">
      <header class="header-modern">
        <div class="logo">
          <h1>📋 Дошка оголошень <span class="beta">Premium</span></h1>
          <p class="header-subtitle">Добірка актуальних оголошень з акцентом на швидкий пошук.</p>
        </div>
        <div class="header-actions">
          <a href="/announcements" class="btn btn-primary" aria-label="Додати нове оголошення">
            Додати
          </a>
        </div>
      </header>

      <main id="main-content" tabindex="-1">
        <form method="GET" class="controls" aria-label="Пошук і сортування оголошень">
          <div class="search-group">
            <label for="search" class="controls-label">Пошук</label>
            <div class="search-row">
              <input id="search" type="text" name="search" value="<%= search %>" placeholder="Шукати оголошення..." class="search-input">
              <button type="submit" class="btn btn-search">Знайти</button>
            </div>
          </div>
          <div class="sort-group">
            <label for="sort" class="controls-label">Сортування</label>
            <select id="sort" name="sort">
              <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Новіші спочатку</option>
              <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Старіші спочатку</option>
            </select>
            <input type="hidden" name="page" value="1">
          </div>
        </form>

        <% if (announcements.length === 0) { %>
          <section class="empty-state" aria-live="polite">
            <h2>Оголошень не знайдено</h2>
            <p>Спробуйте змінити пошуковий запит або скинути фільтри, щоб побачити більше результатів.</p>
            <div class="empty-state-actions">
              <% if (search || sort !== 'newest') { %>
                <a href="/" class="btn btn-secondary">Скинути фільтри</a>
              <% } %>
              <a href="/announcements" class="btn btn-primary">Додати оголошення</a>
            </div>
          </section>
        <% } else { %>
          <div class="announcements-grid">
            <% announcements.forEach((ann, index) => { %>
              <article class="card animate-stagger" style="--delay: <%= index * 0.1 %>s">
                <div class="category-badge card-badge premium-badge" data-category="<%= ann.category %>">
                  <%= ann.category === 'sale' ? '📦 Продаж' : ann.category === 'service' ? '🔧 Послуги' : ann.category === 'job' ? '💼 Робота' : '📌 Інше' %>
                </div>
                <div class="card-content">
                  <h3><%= ann.title %></h3>
                  <p><%= ann.description.length > 100 ? ann.description.substring(0, 100) + '...' : ann.description %></p>
                  <div class="card-meta">
                    <span class="price premium-price"><%= ann.price.toLocaleString('uk-UA') %> грн</span>
                    <span class="date"><%= new Intl.DateTimeFormat('uk-UA', { day: 'numeric', month: 'short' }).format(new Date(ann.createdAt)) %></span>
                  </div>
                </div>
                <a href="/announcements/<%= ann.id %>" class="btn btn-primary card-cta" aria-label="Детальніше про <%= ann.title %>">
                  Детальніше
                </a>
              </article>
            <% }) %>
          </div>

          <% if (totalPages > 1) { %>
            <nav class="pagination">
              <a href="/?page=<%= page - 1 %>&search=<%= encodeURIComponent(search) %>&sort=<%= sort %>" 
                class="page-link <%= !hasPrev ? 'disabled' : '' %>">Попередня</a>

              <% for (let i = 1; i <= totalPages; i++) { %>
                <a href="/?page=<%= i %>&search=<%= encodeURIComponent(search) %>&sort=<%= sort %>" 
                  class="page-link <%= i === page ? 'active' : '' %>"><%= i %></a>
              <% } %>

              <a href="/?page=<%= page + 1 %>&search=<%= encodeURIComponent(search) %>&sort=<%= sort %>" 
                class="page-link <%= !hasNext ? 'disabled' : '' %>">Наступна</a>
            </nav>
          <% } %>
        <% } %>
      </main>
    </div>
  </div>
</body>
</html>
