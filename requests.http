@baseUrl = http://localhost:3000
@email = hw5_user@example.com
@password = secret123
@token = {{login.response.body.token}}

### Register
# @name register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{email}}",
  "password": "{{password}}"
}

### GET /announcements
GET {{baseUrl}}/announcements

### POST /announcements with photo (multipart/form-data)
# @name createWithImage
POST {{baseUrl}}/announcements
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="title"

Продам велосипед Trek
--WebAppBoundary
Content-Disposition: form-data; name="description"

Відмінний стан, алюмінієва рама, пройшов ТО.
--WebAppBoundary
Content-Disposition: form-data; name="price"

8500
--WebAppBoundary
Content-Disposition: form-data; name="category"

sale
--WebAppBoundary
Content-Disposition: form-data; name="contactInfo"

veloman@gmail.com
--WebAppBoundary
Content-Disposition: form-data; name="image"; filename="bike.jpg"
Content-Type: image/jpeg

< ./uploads/bike.jpg
--WebAppBoundary--

### PATCH /announcements/:id with photo
PATCH {{baseUrl}}/announcements/{{createWithImage.response.body.id}}
Authorization: Bearer {{token}}
Content-Type: multipart/form-data; boundary=PatchBoundary

--PatchBoundary
Content-Disposition: form-data; name="price"

8700
--PatchBoundary
Content-Disposition: form-data; name="image"; filename="bike-new.jpg"
Content-Type: image/jpeg

< ./uploads/bike-new.jpg
--PatchBoundary--

### GET /announcements/:id existing
GET {{baseUrl}}/announcements/{{createWithImage.response.body.id}}

### GET /announcements/:id missing
GET {{baseUrl}}/announcements/999999

### DELETE /announcements/:id
DELETE {{baseUrl}}/announcements/{{createWithImage.response.body.id}}
Authorization: Bearer {{token}}

### DELETE /announcements/:id missing
DELETE {{baseUrl}}/announcements/999999
Authorization: Bearer {{token}}

